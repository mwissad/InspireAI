# ═══════════════════════════════════════════════════
#  Inspire AI — Environment Configuration
# ═══════════════════════════════════════════════════
#
#  Copy this file to .env and fill in the values.
#  When deployed as a Databricks App, DATABRICKS_HOST
#  and DATABRICKS_TOKEN are injected automatically.
#
# ═══════════════════════════════════════════════════

# Required — your Databricks workspace URL
# (auto-injected when running as a Databricks App)
DATABRICKS_HOST="https://adb-3642885996758754.14.azuredatabricks.net/"

# Optional — service-principal or PAT token.
# If not set, users must provide their own PAT via the UI.
# (auto-injected when running as a Databricks App)
# DATABRICKS_TOKEN=

# Server port (default: 3001 for dev, 8080 for Databricks App)
# PORT=3001

# Optional — pre-configured notebook path
# NOTEBOOK_PATH=/Users/shared/inspire_ai

# Node environment (production | development)
# NODE_ENV=development

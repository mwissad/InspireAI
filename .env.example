# ═══════════════════════════════════════════════════════════════════════════
#  Inspire AI — LOCAL development (.env in repo root)
# ═══════════════════════════════════════════════════════════════════════════
#
#  Copy to .env and fill in values:
#    cp .env.example .env
#
#  Run the stack:
#    npm run install:all   # once
#    npm run dev           # backend :8080 + Vite (open the Local URL shown)
#
#  Databricks App + installer_workspace.py injects host/SP/warehouse/DB on deploy;
#  do not rely on this file there. For local dev only.
#
# ═══════════════════════════════════════════════════════════════════════════

# --- Workspace connection ---

# Workspace API base (no ?o=… query string). Example GCP:
# DATABRICKS_HOST=https://8259559199054992.2.gcp.databricks.com
DATABRICKS_HOST="https://adb-3642885996758754.14.azuredatabricks.net"

# Personal access token (User Settings → Developer → Access tokens).
# If omitted, use the in-app Workspace setup wizard (PAT stored in browser localStorage).
# DATABRICKS_TOKEN=dapixxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Set all four below to skip the Setup Wizard entirely (local dev) ---

# SQL warehouse id (UUID from SQL Warehouses UI).
# INSPIRE_WAREHOUSE_ID=

# Session tracking database catalog.schema (create in UC or via wizard once).
# INSPIRE_DATABASE=workspace._inspire

# Published Inspire notebook path (omit to auto-resolve). Prefer /Workspace/Shared/... so Results can resolve ./../demos/ beside Shared.
# NOTEBOOK_PATH=/Workspace/Shared/inspire_ai

# --- Usually leave unset for npm run dev ---

# App listen port (default 8080 — must match Vite proxy in frontend/vite.config.js).
# PORT=8080

# Do NOT set to production when using `npm run dev` (keeps PAT wizard behavior correct).
# NODE_ENV=development

# Verbose SP OAuth logs (token fetch / cache). Default: quiet; errors still log.
# DEBUG_SP_AUTH=1

# Installer sets this on the App only. Leave unset locally.
# INSPIRE_AUTO_SETUP=true

# --- Full workspace deploy from laptop (`npm run deploy` = deploy:inspire) ---
# Optional: all-purpose cluster id used to run installer_workspace.py as a Job.
# If unset, the script picks the first RUNNING cluster (must exist).
# INSPIRE_DEPLOY_CLUSTER_ID=0123-234567-abc890
